<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Hediff oculto que lleva el estado de fase de QT y decide cuándo escalar -->
  <HediffDef>
    <defName>QT_Core</defName>
    <hediffClass>QTTermination.Hediff_QTCore</hediffClass>
    <label>núcleo inestable</label>
    <description>Un núcleo de comportamiento que determina el estado emocional de QT. Actualmente estable... por ahora.</description>
    <defaultLabelColor>(0.85, 0.4, 0.75)</defaultLabelColor>
    <isBad>false</isBad>
    <maxSeverity>4.0</maxSeverity>
    <initialSeverity>0.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>0</severityPerDay>
      </li>
    </comps>
  </HediffDef>

  <!-- Fase 1: Carefree - sin penalización, solo cosmético/social -->
  <HediffDef>
    <defName>QT_Phase_Carefree</defName>
    <label>fase: despreocupada</label>
    <description>QT está tranquila y sociable. Todo parece normal.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>despreocupada</label>
        <statOffsets>
          <SocialImpact>0.2</SocialImpact>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <!-- Fase 2: Careless - empieza a subir velocidad de movimiento/ataque -->
  <HediffDef>
    <defName>QT_Phase_Careless</defName>
    <label>fase: descuidada</label>
    <description>La sonrisa de QT empieza a temblar. Sus movimientos son más bruscos y rápidos.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>descuidada</label>
        <statOffsets>
          <MoveSpeed>0.6</MoveSpeed>
          <MeleeHitChance>8</MeleeHitChance>
        </statOffsets>
        <statFactors>
          <MeleeCooldownFactor>0.85</MeleeCooldownFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <!-- Fase 3: Sensory Overload - pulso de área que aturde -->
  <HediffDef>
    <defName>QT_Phase_SensoryOverload</defName>
    <label>fase: sobrecarga sensorial</label>
    <description>QT emite un pulso caótico de luz y sonido. Cualquiera cerca sufre desorientación.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>sobrecarga sensorial</label>
        <statOffsets>
          <MoveSpeed>1.0</MoveSpeed>
          <MeleeHitChance>16</MeleeHitChance>
        </statOffsets>
        <statFactors>
          <MeleeCooldownFactor>0.65</MeleeCooldownFactor>
          <IncomingDamageFactor>0.7</IncomingDamageFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <!-- Efecto aplicado a colonos cercanos durante Sensory Overload -->
  <HediffDef>
    <defName>QT_Disoriented</defName>
    <label>desorientado</label>
    <description>El pulso sensorial de QT ha saturado tus sentidos. Cuesta apuntar y moverse con precisión.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <maxSeverity>1.0</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>600~900</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <statFactors>
          <ShootingAccuracyPawn>0.55</ShootingAccuracyPawn>
          <MoveSpeed>0.7</MoveSpeed>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <!-- Fase final: Termination - carga que explota si no se esquiva a tiempo -->
  <HediffDef>
    <defName>QT_Phase_Termination</defName>
    <label>fase: terminación</label>
    <description>QT ha entrado en su forma final. Un núcleo de energía se está cargando en su interior y no tardará en detonar.</description>
    <hediffClass>QTTermination.Hediff_TerminationCharge</hediffClass>
    <isBad>true</isBad>
    <maxSeverity>1.0</maxSeverity>
    <defaultLabelColor>(1, 0.15, 0.15)</defaultLabelColor>
    <stages>
      <li>
        <minSeverity>0.0</minSeverity>
        <label>cargando</label>
        <statOffsets>
          <MoveSpeed>1.3</MoveSpeed>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.75</minSeverity>
        <label>a punto de detonar</label>
        <statOffsets>
          <MoveSpeed>1.3</MoveSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
